---
BasedOnStyle: LLVM
Language: Cpp
Standard: c++20

ColumnLimit: 120
IndentWidth: 4
TabWidth: 4
UseTab: Never

AccessModifierOffset: -2
NamespaceIndentation: None
BreakBeforeBraces: Attach
IndentCaseLabels: false
AllowShortFunctionsOnASingleLine: Empty

PointerAlignment: Left
ReferenceAlignment: Pointer

SortIncludes: true
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<(CLI|fmt|gtest|nlohmann|oneapi)/.*>$'
    Priority: 2
    SortPriority: 2
  - Regex: '^<.*>$'
    Priority: 1
    SortPriority: 1
  - Regex: '^".*"$'
    Priority: 3
    SortPriority: 3
